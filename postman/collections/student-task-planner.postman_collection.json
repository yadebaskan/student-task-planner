{
  "info": {
    "name": "Student Task Planner API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseURL",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test2@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/register",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test(\"Response confirms registration\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.have.property(\"message\");",
                  "  pm.expect(res.message).to.eql(\"User registered successfully\");",
                  "});",
                  "",
                  "pm.test(\"Response has userId\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.have.property(\"userId\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "if (res.token) {",
                  "  pm.collectionVariables.set(\"authToken\", res.token);",
                  "  console.log(\"authToken saved:\", res.token);",
                  "}",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has a token\", function () {",
                  "  pm.expect(res).to.have.property(\"token\");",
                  "  pm.expect(res.token).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Response has user info\", function () {",
                  "  pm.expect(res).to.have.property(\"user\");",
                  "});",
                  "",
                  "pm.test(\"Token is saved to collection variable\", function () {",
                  "  pm.expect(pm.collectionVariables.get(\"authToken\")).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test2@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/login",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"Response time is under 1000ms\", function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Task",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Study for exam\",\n  \"deadline\": \"2026-06-01\",\n  \"priority\": \"High\",\n  \"category\": \"Study\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/tasks",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test(\"Response has task id\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.have.property(\"id\");",
                  "  pm.collectionVariables.set(\"taskId\", res.id);",
                  "});",
                  "",
                  "pm.test(\"Task title matches\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.title).to.eql(\"Study for exam\");",
                  "});",
                  "",
                  "pm.test(\"Task has priority and category\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.priority).to.eql(\"High\");",
                  "  pm.expect(res.category).to.eql(\"Study\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Task",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/tasks/:id",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{taskId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response confirms update\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an(\"object\");",
                  "  pm.expect(res).to.have.property(\"message\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Task",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks/:id",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{taskId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response confirms deletion\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an(\"object\");",
                  "  pm.expect(res).to.have.property(\"message\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Tasks",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks/search?q=exam",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "exam"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Task Stats",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks/stats",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
                "stats"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Stats response is an object\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an(\"object\");",
                  "  pm.expect(res).to.have.property(\"done\");",
                  "  pm.expect(res).to.have.property(\"todo\");",
                  "  pm.expect(res).to.have.property(\"total\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Tasks by Status - todo",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks/status/todo",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
                "status",
                "todo"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Tasks by Status - done",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks/status/done",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
                "status",
                "done"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Tasks by Deadline",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks/deadline/2026-06-01",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
