            }
          ]
        },
        {
          "name": "Get Tasks by Category",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/tasks/category/Study",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "tasks",
